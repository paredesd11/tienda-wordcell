<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # Previene loops infinitos y redirige TODO a public/
    RewriteCond %{REQUEST_URI} !^/public/
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>

# Bloqueo básico de seguridad (compatible con Apache 2.2 en InfinityFree)
<FilesMatch "\.(env|sql|log)$">
    Order allow,deny
    Deny from all
</FilesMatch>
