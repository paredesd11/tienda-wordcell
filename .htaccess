<IfModule mod_rewrite.c>
    RewriteEngine On

    # Evitar bucles infinitos: no reescribir si la petición ya va hacia /public/
    RewriteCond %{REQUEST_URI} !/public/
    RewriteCond %{REQUEST_URI} !/public$
    
    # Redirigir silenciosamente todo el tráfico a la carpeta public/
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>
