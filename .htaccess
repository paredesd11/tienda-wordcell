<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # Enviar las peticiones de la raíz a la carpeta public
    RewriteRule ^$ public/ [L]
    
    # Enviar todas las demás peticiones que no sean la carpeta public
    RewriteCond %{REQUEST_URI} !^/public/
    RewriteRule (.*) public/$1 [L]
</IfModule>

# Seguridad: ocultar archivos sensibles si alguien intenta acceder directamente
<FilesMatch "(config\.php|\.env|\.sql|\.log)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order Allow,Deny
        Deny from all
    </IfModule>
</FilesMatch>
