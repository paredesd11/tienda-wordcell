# Ocultar listado de directorios y definir índice por defecto
Options -Indexes
DirectoryIndex index.php

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Forzar HTTPS (Compatible con el proxy de InfinityFree)
    RewriteCond %{HTTP:X-Forwarded-Proto} !https
    RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # Si la petición es para un archivo o directorio real (especialmente dentro de public/), detener aquí.
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Redirigir todo lo demás al index real dentro de public/
    # Esto funciona mejor en InfinityFree al apuntar directamente al archivo que maneja el ruteo.
    RewriteRule ^(.*)$ public/index.php?url=$1 [QSA,L]
</IfModule>
