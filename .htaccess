# Ocultar listado de directorios y definir índice por defecto
Options -Indexes
DirectoryIndex index.php

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Si el archivo o directorio existen físicamente, cargarlos (ej: las imágenes o css dentro de public/)
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    
    # Si no, redirigir todo a index.php en la raíz (evitando el error 403 de InfinityFree al reescribir a /public)
    RewriteRule ^(.*)$ index.php?url=$1 [QSA,L]
</IfModule>
